# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=inventory_db

# Backend (auto-built from above in docker-compose)
DATABASE_URL=postgresql://postgres:your_strong_password_here@db:5432/inventory_db

# Frontend (set to deployed backend URL when deploying separately)
VITE_API_URL=https://your-backend-url.onrender.com
